# LLM Backend: "ollama" (local) or "groq" (cloud)
LLM_BACKEND=ollama

# Groq API key (required if LLM_BACKEND=groq)
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Ollama settings (for local backend)
OLLAMA_MODEL=llama3.2:1b
OLLAMA_URL=http://localhost:11434

# Groq settings (for cloud backend)
GROQ_MODEL=llama-3.3-70b-versatile

# Dungeon Master AI settings (falls back to GROQ_API_KEY if DM_API_KEY not set)
DM_ENABLED=true
DM_BACKEND=ollama
DM_MODEL=llama3.2:3b
DM_TEMPERATURE=0.6
